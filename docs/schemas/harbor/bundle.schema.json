{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["manifest", "resources"],
  "properties": {
    "manifest": {
      "type": "object",
      "required": ["version", "schema_version", "exported_at", "source_realm", "type"],
      "properties": {
        "version": { "type": "string" },
        "schema_version": { "type": "integer", "minimum": 0 },
        "exported_at": { "type": "string", "format": "date-time" },
        "source_realm": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["theme", "client", "flow", "role", "full_realm"]
        },
        "selection": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "data"],
        "properties": {
          "key": { "type": "string" },
          "data": {},
          "assets": { "type": "array" },
          "meta": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
