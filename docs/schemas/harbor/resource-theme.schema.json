{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["key", "data"],
  "properties": {
    "key": { "const": "theme" },
    "data": {
      "type": "object",
      "required": ["tokens", "layout", "nodes"],
      "properties": {
        "tokens": { "type": "object" },
        "layout": { "type": "object" },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["node_key", "blueprint"],
            "properties": {
              "node_key": { "type": "string" },
              "blueprint": { "type": ["object", "array"] }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["filename", "mime_type", "asset_type", "data_base64"],
        "properties": {
          "id": { "type": "string" },
          "filename": { "type": "string" },
          "mime_type": { "type": "string" },
          "asset_type": { "type": "string" },
          "data_base64": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "draft_exists": { "type": "boolean" },
        "theme": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "description": { "type": ["string", "null"] },
            "is_system": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "bindings": {
          "type": "object",
          "properties": {
            "default": { "type": "boolean" },
            "clients": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["client_id"],
                "properties": {
                  "client_id": { "type": "string" }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
