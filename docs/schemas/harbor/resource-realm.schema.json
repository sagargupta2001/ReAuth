{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["key", "data"],
  "properties": {
    "key": { "const": "realm" },
    "data": {
      "type": "object",
      "required": [
        "access_token_ttl_secs",
        "refresh_token_ttl_secs",
        "pkce_required_public_clients",
        "lockout_threshold",
        "lockout_duration_secs",
        "flow_bindings"
      ],
      "properties": {
        "access_token_ttl_secs": { "type": "integer" },
        "refresh_token_ttl_secs": { "type": "integer" },
        "pkce_required_public_clients": { "type": "boolean" },
        "lockout_threshold": { "type": "integer" },
        "lockout_duration_secs": { "type": "integer" },
        "flow_bindings": {
          "type": "object",
          "properties": {
            "browser_flow_id": { "type": ["string", "null"] },
            "registration_flow_id": { "type": ["string", "null"] },
            "direct_grant_flow_id": { "type": ["string", "null"] },
            "reset_credentials_flow_id": { "type": ["string", "null"] },
            "invitation_flow_id": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "assets": { "type": "array", "maxItems": 0 },
    "meta": { "type": "object" }
  },
  "additionalProperties": true
}
